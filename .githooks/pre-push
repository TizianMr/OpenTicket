#!/usr/bin/env bash
# =============================================================================
# Pre-push hook — runs code quality checks for backend and frontend
# =============================================================================

set -euo pipefail

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
print_header() { echo -e "\n${BOLD}${CYAN}▶ $1${RESET}"; }
print_step()   { echo -e "  ${YELLOW}→ $1${RESET}"; }
print_ok()     { echo -e "  ${GREEN}✔ $1${RESET}"; }
print_fail()   { echo -e "  ${RED}✘ $1${RESET}"; }

FAILED_CHECKS=()

run_check() {
  local label="$1"
  shift
  print_step "$label"
  if "$@"; then
    print_ok "$label passed"
  else
    print_fail "$label FAILED"
    FAILED_CHECKS+=("$label")
  fi
}

# ── Resolve repo root (works regardless of where git invokes the hook) ────────
REPO_ROOT="$(git rev-parse --show-toplevel)"

BACKEND_DIR="$REPO_ROOT/backend"
FRONTEND_DIR="$REPO_ROOT/frontend"       

# ── Detect Maven wrapper vs system Maven ──────────────────────────────────────
if [[ -f "$BACKEND_DIR/mvnw" ]]; then
  MVN="$BACKEND_DIR/mvnw"
else
  MVN="mvn"
fi

# =============================================================================
# BACKEND checks
# =============================================================================
print_header "Backend checks (Spring Boot)"

run_check "Spotless — code formatting" \
  "$MVN" -f "$BACKEND_DIR/pom.xml" spotless:check --batch-mode -q

run_check "Checkstyle — style violations" \
  "$MVN" -f "$BACKEND_DIR/pom.xml" checkstyle:check --batch-mode -q

# =============================================================================
# FRONTEND checks
# =============================================================================
print_header "Frontend checks (Angular)"

# Ensure node_modules exist
if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
  print_step "node_modules not found — running npm ci"
  npm ci --prefix "$FRONTEND_DIR"
fi

run_check "ESLint — lint" \
  npm run lint --prefix "$FRONTEND_DIR"


# =============================================================================
# Summary
# =============================================================================
echo ""
if [[ ${#FAILED_CHECKS[@]} -eq 0 ]]; then
  echo -e "${BOLD}${GREEN}All checks passed — push allowed ✔${RESET}\n"
  exit 0
else
  echo -e "${BOLD}${RED}Push BLOCKED — the following checks failed:${RESET}"
  for check in "${FAILED_CHECKS[@]}"; do
    echo -e "  ${RED}• $check${RESET}"
  done
  echo -e "\nFix the issues above and try again.\n"
  exit 1
fi
